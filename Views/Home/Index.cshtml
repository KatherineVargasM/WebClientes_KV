@{
    ViewData["Title"] = "Inicio";
}

<div class="container d-flex flex-column align-items-center justify-content-center" style="font-family: 'Segoe UI', sans-serif; min-height: 70vh; text-align: center;">

    <h1 class="display-5 mb-4" style="font-weight: 300; color: #2b303a; letter-spacing: -0.5px;">
        Gestión de Clientes
    </h1>

    <div class="mb-4 mt-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" fill="#51b5ae" class="bi bi-people" viewBox="0 0 16 16" style="opacity: 0.85;">
            <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1zm-7.978-1L7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.004-.014.002H7.022zM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4m3-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0M6.936 9.28a6 6 0 0 0-1.23-.247A7 7 0 0 0 5 9c-4 0-5 3-5 4q0 1 1 1h4.216A2.24 2.24 0 0 1 5 13c0-1.01.377-2.042 1.09-2.904.243-.294.526-.569.846-.816M4.92 7.393a3 3 0 1 1 0-4.65 3 3 0 0 1 0 4.65" />
        </svg>
    </div>

    <div class="mt-3">
        <a asp-controller="Clientes" asp-action="Index" class="btn text-white" style="background-color: #51b5ae; font-weight: 500; padding: 10px 35px; border-radius: 6px; box-shadow: 0 4px 10px rgba(81, 181, 174, 0.15); border: none; font-size: 1.05rem;">
            Lista de Clientes
        </a>
    </div>

</div>
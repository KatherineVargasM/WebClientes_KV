@model Web_Clientes.Models.ClienteModel

@{
    ViewData["Title"] = "Editar Cliente";
}

<h1 class="display-5 mt-4 mb-3" style="font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, Roboto, sans-serif; color: #2b303a; font-weight: 300; letter-spacing: -0.5px;">
    Editar Cliente
</h1>

<hr style="border-color: #51b5ae; opacity: 0.2;" />

<div class="row mt-4" style="font-family: 'Segoe UI', sans-serif;">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="id" />
            <input type="hidden" asp-for="Fecha_Registro" />

            <div class="form-group mb-3">
                <label asp-for="Cedula" class="control-label" style="font-weight: 500; color: #495057;"></label>
                <input asp-for="Cedula" class="form-control" style="border-radius: 6px; border: 1px solid #ced4da;" />
                <span asp-validation-for="Cedula" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Nombres" class="control-label" style="font-weight: 500; color: #495057;"></label>
                <input asp-for="Nombres" class="form-control" style="border-radius: 6px; border: 1px solid #ced4da;" />
                <span asp-validation-for="Nombres" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Apellidos" class="control-label" style="font-weight: 500; color: #495057;"></label>
                <input asp-for="Apellidos" class="form-control" style="border-radius: 6px; border: 1px solid #ced4da;" />
                <span asp-validation-for="Apellidos" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Fecha_Nacimiento" class="control-label" style="font-weight: 500; color: #495057;"></label>
                <input asp-for="Fecha_Nacimiento" class="form-control" style="border-radius: 6px; border: 1px solid #ced4da;" />
                <span asp-validation-for="Fecha_Nacimiento" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Genero" class="control-label" style="font-weight: 500; color: #495057;"></label>
                <select asp-for="Genero" class="form-control" style="border-radius: 6px; border: 1px solid #ced4da;">
                    <option value="Masculino">Masculino</option>
                    <option value="Femenino">Femenino</option>
                    <option value="Otro">Otro</option>
                </select>
                <span asp-validation-for="Genero" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Celular" class="control-label" style="font-weight: 500; color: #495057;"></label>
                <input asp-for="Celular" class="form-control" style="border-radius: 6px; border: 1px solid #ced4da;" />
                <span asp-validation-for="Celular" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Correo_Electronico" class="control-label" style="font-weight: 500; color: #495057;"></label>
                <input asp-for="Correo_Electronico" class="form-control" style="border-radius: 6px; border: 1px solid #ced4da;" />
                <span asp-validation-for="Correo_Electronico" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Direccion" class="control-label" style="font-weight: 500; color: #495057;"></label>
                <input asp-for="Direccion" class="form-control" style="border-radius: 6px; border: 1px solid #ced4da;" />
                <span asp-validation-for="Direccion" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Ciudad" class="control-label" style="font-weight: 500; color: #495057;"></label>
                <input asp-for="Ciudad" class="form-control" style="border-radius: 6px; border: 1px solid #ced4da;" />
                <span asp-validation-for="Ciudad" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Provincia" class="control-label" style="font-weight: 500; color: #495057;"></label>
                <input asp-for="Provincia" class="form-control" style="border-radius: 6px; border: 1px solid #ced4da;" />
                <span asp-validation-for="Provincia" class="text-danger"></span>
            </div>

            <div class="form-group mt-4 mb-5">
                <input type="submit" value="Guardar Cambios" class="btn text-white" style="background-color: #51b5ae; font-weight: 500; padding: 8px 24px; border-radius: 6px; border: none; margin-right: 8px;" />
                <a asp-action="Index" class="btn" style="background-color: #e9ecef; color: #495057; font-weight: 500; padding: 8px 24px; border-radius: 6px; border: 1px solid #dee2e6;">Regresar</a>
            </div>
        </form>
    </div>
</div>
@model Web_Clientes.Models.ClienteModel

@{
    ViewData["Title"] = "Eliminar Cliente";
}

<h1 class="display-5 mt-4 mb-3" style="font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, Roboto, sans-serif; color: #dc3545; font-weight: 300; letter-spacing: -0.5px;">
    ¿Está seguro que desea eliminar este cliente?
</h1>

<hr style="border-color: #dc3545; opacity: 0.2;" />

<div class="mt-4" style="font-family: 'Segoe UI', sans-serif; max-width: 700px;">
    <div class="row py-2" style="border-bottom: 1px solid #dee2e6;">
        <div class="col-sm-4" style="font-weight: 600; color: #495057;">ID</div>
        <div class="col-sm-8" style="font-weight: bold; color: #212529;">@Model.id</div>
    </div>
    <div class="row py-2" style="border-bottom: 1px solid #dee2e6;">
        <div class="col-sm-4" style="font-weight: 600; color: #495057;">Cédula</div>
        <div class="col-sm-8">@Model.Cedula</div>
    </div>
    <div class="row py-2" style="border-bottom: 1px solid #dee2e6;">
        <div class="col-sm-4" style="font-weight: 600; color: #495057;">Nombre Completo</div>
        <div class="col-sm-8">@Model.Nombres @Model.Apellidos</div>
    </div>
    <div class="row py-2" style="border-bottom: 1px solid #dee2e6;">
        <div class="col-sm-4" style="font-weight: 600; color: #495057;">Celular</div>
        <div class="col-sm-8">@Model.Celular</div>
    </div>
    <div class="row py-2" style="border-bottom: 1px solid #dee2e6;">
        <div class="col-sm-4" style="font-weight: 600; color: #495057;">Correo Electrónico</div>
        <div class="col-sm-8">@Model.Correo_Electronico</div>
    </div>
</div>

<div class="mt-4 mb-5" style="font-family: 'Segoe UI', sans-serif;">
    <form asp-action="Delete">
        <input type="hidden" asp-for="id" />
        <input type="submit" value="Eliminar" class="btn" style="background-color: #f8d7da; color: #721c24; font-weight: 500; border: 1px solid #f5c6cb; border-radius: 6px; padding: 8px 24px; margin-right: 8px;" />
        <a asp-action="Index" class="btn" style="background-color: #e9ecef; color: #495057; font-weight: 500; padding: 8px 24px; border-radius: 6px; border: 1px solid #dee2e6;">Cancelar</a>
    </form>
</div>